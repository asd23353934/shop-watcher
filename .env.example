# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Shared secret between Worker and Next.js API (required)
WORKER_SECRET=

# Next.js API base URL, e.g. https://your-app.vercel.app (required)
NEXT_PUBLIC_API_URL=

# Scan interval in seconds (optional, default: 300)
CHECK_INTERVAL=300
