// Prisma schema for Shop Watcher SaaS
// SeenItem table records notified items with user, platform, and item_id as unique key
// SeenItem unique constraint prevents duplicate rows

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())

  keywords             Keyword[]
  notificationSetting  NotificationSetting?
  seenItems            SeenItem[]
  platformScanStatuses PlatformScanStatus[]
  circleFollows        CircleFollow[]
  tags                 Tag[]
  tagRules             TagRule[]
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywordTags  KeywordTag[]
  circleTags   CircleFollowTag[]
  tagRules     TagRule[]
  seenItemTags SeenItemTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TagRule {
  id            String   @id @default(cuid())
  userId        String
  pattern       String
  tagId         String
  enabled       Boolean  @default(true)
  systemDefault Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

model SeenItemTag {
  seenItemId String
  tagId      String

  seenItem SeenItem @relation(fields: [seenItemId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([seenItemId, tagId])
  @@index([tagId])
}

model KeywordTag {
  keywordId String
  tagId     String

  keyword Keyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([keywordId, tagId])
  @@index([tagId])
}

model CircleFollowTag {
  circleFollowId String
  tagId          String

  circleFollow CircleFollow @relation(fields: [circleFollowId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([circleFollowId, tagId])
  @@index([tagId])
}

model Keyword {
  id                String   @id @default(cuid())
  userId            String
  keyword           String
  platforms         String[]
  minPrice          Float?
  maxPrice          Float?
  active            Boolean  @default(true)
  blocklist         String[] @default([])
  mustInclude       String[] @default([])
  matchMode         String   @default("any")
  sellerBlocklist   String[] @default([])
  discordWebhookUrl String?
  maxNotifyPerScan  Int?
  createdAt         DateTime @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  seenItems SeenItem[]
  tags      KeywordTag[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([active, createdAt(sort: Desc)])
}

model NotificationSetting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  discordWebhookUrl     String?
  discordUserId         String?
  emailEnabled          Boolean  @default(false)
  globalSellerBlocklist String[] @default([])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScanLog {
  id        String   @id @default(cuid())
  scannedAt DateTime
  createdAt DateTime @default(now())
}

model PlatformScanStatus {
  id          String    @id @default(cuid())
  userId      String
  platform    String
  lastSuccess DateTime?
  lastError   String?
  failCount   Int       @default(0)
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

model PlatformCanaryStatus {
  id                    String    @id @default(cuid())
  platform              String    @unique
  lastRunAt             DateTime?
  itemCount             Int       @default(0)
  domIntact             Boolean   @default(true)
  consecutiveEmptyCount Int       @default(0)
  healthState           String    @default("healthy")
  unhealthyReason       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model CircleFollow {
  id         String   @id @default(cuid())
  userId     String
  platform   String // "booth" | "dlsite"
  circleId   String // 平台上的店家/社團 ID
  circleName String
  webhookUrl String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags CircleFollowTag[]

  @@unique([userId, platform, circleId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([active, createdAt(sort: Desc)])
}

model SeenItem {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  itemId    String
  keyword   String
  firstSeen DateTime @default(now())
  lastPrice Float?
  keywordId String?
  itemName  String?
  itemUrl   String?
  imageUrl  String?

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywordRef Keyword?      @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  tags       SeenItemTag[]

  @@unique([userId, platform, itemId])
  @@index([userId, keywordId, firstSeen(sort: Desc)])
  @@index([userId, firstSeen(sort: Desc)])
  @@index([userId, platform, firstSeen(sort: Desc)])
}
