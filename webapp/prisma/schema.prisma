// Prisma schema for Shop Watcher SaaS
// SeenItem table records notified items with user, platform, and item_id as unique key
// SeenItem unique constraint prevents duplicate rows

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())

  keywords            Keyword[]
  notificationSetting NotificationSetting?
  seenItems           SeenItem[]
}

model Keyword {
  id        String   @id @default(cuid())
  userId    String
  keyword   String
  platforms String[]
  minPrice  Float?
  maxPrice  Float?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  seenItems SeenItem[]
}

model NotificationSetting {
  id                 String  @id @default(cuid())
  userId             String  @unique
  discordWebhookUrl  String?
  discordUserId      String?
  emailAddress       String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SeenItem {
  id        String   @id @default(cuid())
  userId    String
  platform  String
  itemId    String
  keyword   String
  firstSeen DateTime @default(now())
  keywordId String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keywordRef  Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([userId, platform, itemId])
}
